# Resumora — copy to ".env.local" and fill values (never commit .env.local).
# Restart dev server after changes.

# --- Stripe Checkout (pricing page) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — Dashboard → Webhooks → your endpoint (/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=

# One Stripe Price ID per tier (aliases — set any ONE valid price_* per tier)
NEXT_PUBLIC_STRIPE_PRICE_BASIC=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ELITE=

# Alternate names (optional — server / hidden price IDs)
# NEXT_PUBLIC_STRIPE_PRICE_STARTER=
# NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=
# STRIPE_PRICE_BASIC=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_PROFESSIONAL=
# STRIPE_PRICE_ELITE=

# --- Neon shared memory / engagement ---
# NEON_DATABASE_URL=

# --- Optional ---
# PORT=3001
# BOSSMIND_DIAGNOSTICS=1
# SENTRY_* (production)
