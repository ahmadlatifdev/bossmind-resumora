# Copy to `.env.local` for local development. Do not commit real secrets — `.env*` stays gitignored
# except this template.
#
# STRIPE_SECRET_KEY (`sk_live_…` / `sk_test_…`) must live only in `.env.local` or your host’s
# secret store. Never expose it to the browser, share it in tickets, or commit it.

# Canonical client-facing URL (footer link + social fallbacks)
NEXT_PUBLIC_SITE_URL=https://resumora.net

# Stripe — use test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe Price IDs — create Products/Prices in Dashboard; server resolves checkout by plan id.
# Option A (recommended for localhost): server-only — no need to expose IDs to the browser
STRIPE_PRICE_BASIC=price_replace_me
STRIPE_PRICE_PROFESSIONAL=price_replace_me
STRIPE_PRICE_ELITE=price_replace_me

# Option B: legacy NEXT_PUBLIC aliases (still supported)
# NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_replace_me
# NEXT_PUBLIC_STRIPE_PRICE_PRO=price_replace_me
# NEXT_PUBLIC_STRIPE_PRICE_ELITE=price_replace_me

# Optional social profile URLs (otherwise footer icons fall back to NEXT_PUBLIC_SITE_URL)
# NEXT_PUBLIC_SOCIAL_FACEBOOK=
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=
# NEXT_PUBLIC_SOCIAL_TIKTOK=
# NEXT_PUBLIC_SOCIAL_YOUTUBE=
# NEXT_PUBLIC_SOCIAL_LINKEDIN=
# NEXT_PUBLIC_SOCIAL_PINTEREST=
# NEXT_PUBLIC_SOCIAL_X=
