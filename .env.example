# Resumora — copy to ".env.local" and fill values (never commit .env.local).
# Restart dev server after changes.

# --- Stripe Checkout (pricing page) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — Dashboard → Webhooks → your endpoint (/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=

# --- Canonical Stripe Price IDs (ONE valid price_* per tier — Professional uses *_PRO) ---
# Create one-time Prices only (NOT recurring/monthly); Checkout uses mode=payment ($19 / $49 / $99 / $110 tiers in UI).
# Dashboard → Products → Prices — copy full IDs starting with price_
NEXT_PUBLIC_STRIPE_PRICE_BASIC=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ELITE=
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIAL_ADVANCED=

# Legacy / hidden aliases (optional — see lib/marketing/stripe-plan-map.js PLAN_PRICE_ENV_KEYS)
# NEXT_PUBLIC_STRIPE_PRICE_STARTER=
# NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=
# NEXT_PUBLIC_STRIPE_PRICE_ID_PROFESSIONAL=
# STRIPE_PRICE_BASIC=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_PROFESSIONAL=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_PROFESSIONAL=
# STRIPE_PRICE_ELITE=

# --- Neon shared memory / engagement ---
# NEON_DATABASE_URL=

# --- Optional: Google Search Console HTML tag (meta google-site-verification) ---
# NEXT_PUBLIC_GSC_VERIFICATION=
# DNS TXT recovery + API probe (worker/local only — not NEXT_PUBLIC):
# GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# npm run resumora:gsc:verify-recovery

# --- Canonical site URL for sitemap, robots, JSON-LD (production: https://resumora.net) ---
# NEXT_PUBLIC_SITE_URL=https://resumora.net

# --- Organization sameAs (comma or newline separated HTTPS profile URLs for JSON-LD) ---
# NEXT_PUBLIC_ORG_SAME_AS=https://www.linkedin.com/company/your-org,https://www.instagram.com/yourhandle

# --- Google Analytics 4 (gtag in pages/_document.js) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Microsoft Clarity (public project id only — pages/_document.js) ---
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Bing Webmaster Tools HTML tag (msvalidate.01 — pages/_document.js) ---
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --- BossMind SEO stack: worker-only keys (Railway — never NEXT_PUBLIC_, never commit) ---
# SE_RANKING_API_KEY=
# NEURONWRITER_API_KEY=
# LOWFRUITS_API_KEY=
# GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=

# --- Railway closed-loop repair (worker + webhook; secrets in Railway) ---
# BOSSMIND_RAILWAY_WEBHOOK_SECRET=
# RAILWAY_TOKEN=
# BOSSMIND_RAILWAY_PROJECT_ID=
# BOSSMIND_RAILWAY_ENVIRONMENT_ID=
# BOSSMIND_RAILWAY_SERVICE_ID=
# BOSSMIND_RAILWAY_AUTO_REDEPLOY=0
# BOSSMIND_RAILWAY_AUTO_PUSH=0
# BOSSMIND_RAILWAY_RUN_BUILD_GUARD=0
# BOSSMIND_RAILWAY_HEALTH_ORIGIN=https://resumora.net
# BOSSMIND_RAILWAY_REPAIR_EMERGENCY_STOP=0
# BOSSMIND_RAILWAY_REPAIR_MAX_PER_FINGERPRINT=6

# BOSSMIND_CODEX_LAYER_ENABLED=0
# BOSSMIND_GITHUB_APP_ID=
# BOSSMIND_GITHUB_APP_INSTALLATION_ID=

# BOSSMIND_SUPPORT_AI_AUTO_SEND=0
# BOSSMIND_SUPPORT_AI_EMERGENCY_STOP=0

# BOSSMIND_AI_VIDEO_ADMIN_SECRET=
# BOSSMIND_AI_VIDEO_N8N_SECRET=
# BOSSMIND_AI_VIDEO_PROJECT_KEY=ai-video-generator
# BOSSMIND_AI_VIDEO_CHANNEL_NAME=VibeVoyage
# BOSSMIND_AI_VIDEO_TAGLINE=   (optional; default from config/vibevoyage-brand.json)
# BOSSMIND_AI_VIDEO_MISSION=   (optional)
# BOSSMIND_AI_VIDEO_WORKSPACE= (optional dir for scene/VO/temp assets; default OS temp)
# BOSSMIND_AI_VIDEO_MAX_SCENE_RETRIES=5
# BOSSMIND_AI_VIDEO_DEFAULT_SCENE_PROVIDER=webhook
# BOSSMIND_AI_VIDEO_SCENE_WEBHOOK_URL=
# BOSSMIND_AI_VIDEO_SCENE_WEBHOOK_SECRET=
# BOSSMIND_AI_VIDEO_PUBLISH_WEBHOOK_URL=
# BOSSMIND_AI_VIDEO_PUBLISH_WEBHOOK_SECRET=
# DEEPSEEK_API_KEY=   (scenario JSON)
# DEEPSEEK_API_BASE=  (optional)
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_API_KEY=     (TTS + Whisper)
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# FFMPEG_PATH=ffmpeg  (or full path on Windows)
# Worker daemon / cron:
# BOSSMIND_AI_VIDEO_ORCH_POLL_MS=8000
# BOSSMIND_AI_VIDEO_ORCH_MAX_STEPS=
# BOSSMIND_AI_VIDEO_REQUIRE_SCRIPT_APPROVAL=1  (optional; fail scenario_build if review_status set and not approved)

# BOSSMIND_DIAGNOSTICS=1
# SENTRY_* (production)
