{
  "version": 2,
  "project": "resumora",
  "immutableProductionBaseline": {
    "configPath": "config/bossmind-immutable-production-baseline.json",
    "snapshotDir": "config/bossmind-baseline-snapshots/luxury-v1",
    "notes": "Sealed checksums + on-disk snapshots; npm run bossmind:baseline:seal after explicit UI approval. Deploy uses bossmind:immutable:verify."
  },
  "description": "Single active luxury marketing baseline authority (localhost + deploy + Neon sync)",
  "authorityKey": "luxury_ui_baseline",
  "canonicalRoutes": {
    "homePath": "/",
    "homePageSource": "components/marketing/HomePage.jsx",
    "indexBootstrap": "pages/index.js",
    "clientRedirectSources": ["/client", "/client/"]
  },
  "requiredHomeHtmlMarkers": [
    "id=\"top\"",
    "id=\"home-intake\"",
    "id=\"pricing\"",
    "data-rs-pricing-ui=\"20260517-ea-v3-img2\"",
    "data-rs-pricing-order=\"basic,professional,elite,essential_advanced\"",
    "data-tier=\"essential_advanced\"",
    "rs-week-main",
    "rs-btn-accent",
    "rs-cta-strip",
    "rs-pricing-grid",
    "--rs-gold:",
    "--rs-bg-deep:",
    "--rs-border-strong:",
    "--rs-shadow-card:"
  ],
  "forbiddenLiveHtmlPatterns": [
    "Trust at a glance",
    "rs-trust-panel--slim",
    "Greenhouse · Lever · Workday"
  ],
  "forbiddenMinimalHomeIndicators": [],
  "fingerprintExtraPaths": [
    "config/bossmind-protected-ui-authority.json",
    "config/branding-asset-version.json",
    "config/bossmind-ultra-antileak-policy.json",
    "lib/marketing/branding-assets.js",
    "pages/_document.js",
    "pages/_app.js",
    "pages/api/branding-manifest.js",
    "public/sw.js",
    "components/marketing/InstallPrompt.jsx"
  ]
}
