{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListAllBucketsForCliValidation",
      "Effect": "Allow",
      "Action": ["s3:ListAllMyBuckets", "s3:GetAccountPublicAccessBlock"],
      "Resource": "*"
    },
    {
      "Sid": "ResumoraBucketList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation", "s3:GetBucketVersioning"],
      "Resource": "arn:aws:s3:::bossmind-resumora-uploads-377426330385"
    },
    {
      "Sid": "ResumoraObjectCrud",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts",
        "s3:GetObjectAttributes"
      ],
      "Resource": "arn:aws:s3:::bossmind-resumora-uploads-377426330385/*"
    }
  ]
}
