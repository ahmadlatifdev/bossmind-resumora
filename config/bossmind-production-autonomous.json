    "logoPath": "/brand/resumora-logo-official.jpg",
    "forbiddenPatterns": ["Trust at a glance", "rs-trust-panel--slim"]
  },
  "predictive": {
    "blockDeployRiskThreshold": 75,
    "requireEnv": [
      "NEXT_PUBLIC_STRIPE_PRICE_BASIC",
      "NEXT_PUBLIC_STRIPE_PRICE_PRO",
      "NEXT_PUBLIC_STRIPE_PRICE_ELITE"
    ]
  },
  "continuousMonitor": {
    "defaultIntervalMs": 300000,
    "screenshotAuditEveryCycles": 12,
    "fullOptimizationEveryCycles": 4
  },
  "projects": [
    "resumora",
    "bossmind-capital",
    "ai-video-generator",
    "elegancyart",
    "tiktok-ai"
