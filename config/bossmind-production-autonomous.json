{
  "version": 2,
  "targetOverallPercent": 98,
  "domainTargets": {
    "sharedMemory": 96,
    "errorMemory": 94,
    "antiLeak": 96,
    "runtimeSync": 94,
    "autoRecovery": 93,
    "deploymentVerification": 94,
    "crossProjectMemory": 94,
    "autonomousValidation": 94,
    "predictivePrevention": 90,
    "selfHealingChain": 90,
    "continuousMonitoring": 92
  },
  "errorPatternRegistry": "config/bossmind-error-pattern-registry.json",
